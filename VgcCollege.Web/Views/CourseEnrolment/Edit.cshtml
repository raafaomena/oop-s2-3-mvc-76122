@model VgcCollege.Web.Models.CourseEnrolment

@{
    ViewData["Title"] = "Edit Enrolment";
}

<h1>Edit Enrolment</h1>

<form asp-action="Edit">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />
    
    <div class="form-group">
        <label asp-for="StudentProfileId" class="control-label">Student</label>
        <select asp-for="StudentProfileId" class="form-control" asp-items="ViewBag.Students as SelectList">
            <option value="">Select Student</option>
        </select>
        <span asp-validation-for="StudentProfileId" class="text-danger"></span>
    </div>
    
    <div class="form-group">
        <label asp-for="CourseId" class="control-label">Course</label>
        <select asp-for="CourseId" class="form-control" asp-items="ViewBag.Courses as SelectList">
            <option value="">Select Course</option>
        </select>
        <span asp-validation-for="CourseId" class="text-danger"></span>
    </div>
    
    <div class="form-group">
        <label asp-for="Status" class="control-label"></label>
        <select asp-for="Status" class="form-control">
            <option value="Active">Active</option>
            <option value="Completed">Completed</option>
            <option value="Dropped">Dropped</option>
        </select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>
    
    <div class="form-group mt-3">
        <input type="submit" value="Save" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</form>