@model VgcCollege.Web.Models.CourseEnrolment

@{
    ViewData["Title"] = "Delete Enrolment";
}

<h1>Delete Enrolment</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this enrolment?</h3>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Student</dt>
            <dd class="col-sm-9">@Model.StudentProfile?.Name</dd>
            
            <dt class="col-sm-3">Course</dt>
            <dd class="col-sm-9">@Model.Course?.Name</dd>
            
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>