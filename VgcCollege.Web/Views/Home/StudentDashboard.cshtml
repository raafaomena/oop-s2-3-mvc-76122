@{
    ViewData["Title"] = "Student Dashboard";
}

<h1>Welcome, @ViewBag.StudentName</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">My Courses</h5>
                <p class="card-text display-4">@ViewBag.TotalCourses</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">Assignments Completed</h5>
                <p class="card-text display-4">@ViewBag.TotalAssignments</p>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5>My Enrolled Courses</h5>
            </div>
            <div class="card-body">
                @{
                    var myEnrolments = ViewBag.MyEnrolments as List<VgcCollege.Web.Models.CourseEnrolment>;
                }
                @if (myEnrolments != null && myEnrolments.Any())
                {
                    foreach (var enrolment in myEnrolments)
                    {
                        <div class="alert alert-success">
                            <strong>@enrolment.Course?.Name</strong><br />
                            Enrolled: @enrolment.EnrolDate.ToShortDateString()<br />
                            Status: @enrolment.Status<br />
                            <a asp-controller="Assignment" asp-action="MyAssignments" class="btn btn-sm btn-primary">My Grades</a>
                            <a asp-controller="Exam" asp-action="MyResults" class="btn btn-sm btn-info">Exam Results</a>
                        </div>
                    }
                }
                else
                {
                    <p>You are not enrolled in any courses yet.</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5>Recent Assignment Results</h5>
            </div>
            <div class="card-body">
                @{
                    var myAssignments = ViewBag.MyAssignments as List<VgcCollege.Web.Models.AssignmentResult>;
                }
                @if (myAssignments != null && myAssignments.Any())
                {
                    foreach (var result in myAssignments)
                    {
                        double percentage = (double)result.Score / (result.Assignment?.MaxScore ?? 1) * 100;
                        <div class="alert alert-info">
                            <strong>@result.Assignment?.Title</strong> - @result.Assignment?.Course?.Name<br />
                            Score: @result.Score / @result.Assignment?.MaxScore (@percentage.ToString("F1")%)<br />
                            Feedback: @result.Feedback
                        </div>
                    }
                }
                else
                {
                    <p>No assignment results available yet.</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5>Quick Links</h5>
            </div>
            <div class="card-body">
                <a asp-controller="StudentProfile" asp-action="MyProfile" class="btn btn-primary">My Profile</a>
                <a asp-controller="Assignment" asp-action="MyAssignments" class="btn btn-success">My Assignments</a>
                <a asp-controller="Exam" asp-action="MyResults" class="btn btn-info">Exam Results</a>
            </div>
        </div>
    </div>
</div>