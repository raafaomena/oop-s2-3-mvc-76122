@model VgcCollege.Web.Models.StudentProfile

@{
    ViewData["Title"] = "My Profile";
}

<h1>My Profile</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h3>Personal Information</h3>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>
                    
                    <dt class="col-sm-4">Student Number</dt>
                    <dd class="col-sm-8">@Model.StudentNumber</dd>
                    
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>
                    
                    <dt class="col-sm-4">Phone</dt>
                    <dd class="col-sm-8">@Model.Phone</dd>
                    
                    <dt class="col-sm-4">Address</dt>
                    <dd class="col-sm-8">@Model.Address</dd>
                    
                    <dt class="col-sm-4">Date of Birth</dt>
                    <dd class="col-sm-8">@Model.DateOfBirth.ToShortDateString()</dd>
                </dl>
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h3>My Courses</h3>
            </div>
            <div class="card-body">
                @{
                    var enrolments = ViewBag.Enrolments as List<VgcCollege.Web.Models.CourseEnrolment>;
                }
                @if (enrolments != null && enrolments.Any())
                {
                    <ul class="list-group">
                        @foreach (var enrolment in enrolments)
                        {
                            <li class="list-group-item">
                                <strong>@enrolment.Course?.Name</strong><br />
                                Status: @enrolment.Status<br />
                                Enrolled: @enrolment.EnrolDate.ToShortDateString()
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">You are not enrolled in any courses yet.</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h3>My Assignment Results</h3>
            </div>
            <div class="card-body">
                @{
                    var assignmentResults = ViewBag.AssignmentResults as List<VgcCollege.Web.Models.AssignmentResult>;
                }
                @if (assignmentResults != null && assignmentResults.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Assignment</th>
                                <th>Course</th>
                                <th>Score</th>
                                <th>Max Score</th>
                                <th>Feedback</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var result in assignmentResults)
                            {
                                <tr>
                                    <td>@result.Assignment?.Title</td>
                                    <td>@result.Assignment?.Course?.Name</td>
                                    <td>@result.Score</td>
                                    <td>@result.Assignment?.MaxScore</td>
                                    <td>@result.Feedback</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No assignment results available yet.</p>
                }
            </div>
        </div>
    </div>
</div>

<p class="mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to Home</a>
</p>