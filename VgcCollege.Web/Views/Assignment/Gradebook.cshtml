@{
    var assignment = ViewBag.Assignment as VgcCollege.Web.Models.Assignment;
    var results = ViewBag.Results as Dictionary<int, VgcCollege.Web.Models.AssignmentResult>;
    var students = ViewBag.Students as List<VgcCollege.Web.Models.StudentProfile>;
}

<h1>Gradebook: @assignment?.Title</h1>
<h4>Course: @assignment?.Course?.Name</h4>
<hr />

<form method="post" asp-action="SaveGrade">
    <input type="hidden" name="assignmentId" value="@assignment?.Id" />
    <table class="table table-striped">
        <thead>
        <tr>
            <th>Student</th>
            <th>Score (Max: @assignment?.MaxScore)</th>
            <th>Feedback</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var student in students)
        {
            var result = results.ContainsKey(student.Id) ? results[student.Id] : null;
            <tr>
                <td>@student.Name</td>
                <td>
                    <input type="number" name="score" value="@(result?.Score ?? 0)" 
                           class="form-control" style="width: 100px" 
                           min="0" max="@assignment?.MaxScore" />
                    <input type="hidden" name="studentId" value="@student.Id" />
                </td>
                <td>
                    <input type="text" name="feedback" value="@result?.Feedback" 
                           class="form-control" style="width: 200px" />
                </td>
                <td>
                    <button type="submit" class="btn btn-sm btn-primary">Save</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
</form>

<p>
    <a asp-action="Index" class="btn btn-secondary">Back to Assignments</a>
</p>