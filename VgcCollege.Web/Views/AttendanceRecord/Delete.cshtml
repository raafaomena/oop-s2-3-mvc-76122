@model VgcCollege.Web.Models.AttendanceRecord

@{
    ViewData["Title"] = "Delete Attendance";
}

<h1>Delete Attendance Record</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this attendance record?</h3>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Student</dt>
            <dd class="col-sm-9">@Model.CourseEnrolment?.StudentProfile?.Name</dd>
            
            <dt class="col-sm-3">Course</dt>
            <dd class="col-sm-9">@Model.CourseEnrolment?.Course?.Name</dd>
            
            <dt class="col-sm-3">Week</dt>
            <dd class="col-sm-9">@Model.WeekNumber</dd>
            
            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9">@Model.Date.ToShortDateString()</dd>
            
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.Present)
                {
                    <span class="badge bg-success">Present</span>
                }
                else
                {
                    <span class="badge bg-danger">Absent</span>
                }
            </dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>