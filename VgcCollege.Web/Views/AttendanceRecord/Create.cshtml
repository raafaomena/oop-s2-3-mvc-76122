@model VgcCollege.Web.Models.AttendanceRecord

@{
    ViewData["Title"] = "Add Attendance";
}

<h1>Add Attendance Record</h1>

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    
    <div class="form-group">
        <label asp-for="CourseEnrolmentId" class="control-label">Student/Course</label>
        <select asp-for="CourseEnrolmentId" class="form-control" asp-items="ViewBag.Enrolments as SelectList">
            <option value="">Select Enrolment</option>
        </select>
        <span asp-validation-for="CourseEnrolmentId" class="text-danger"></span>
    </div>
    
    <div class="form-group">
        <label asp-for="WeekNumber" class="control-label">Week Number</label>
        <input asp-for="WeekNumber" class="form-control" type="number" min="1" max="52" />
        <span asp-validation-for="WeekNumber" class="text-danger"></span>
    </div>
    
    <div class="form-group form-check">
        <input asp-for="Present" class="form-check-input" />
        <label asp-for="Present" class="form-check-label">Present</label>
    </div>
    
    <div class="form-group mt-3">
        <input type="submit" value="Create" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</form>