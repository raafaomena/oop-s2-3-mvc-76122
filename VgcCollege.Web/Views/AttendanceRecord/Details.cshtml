@model VgcCollege.Web.Models.AttendanceRecord

@{
    ViewData["Title"] = "Attendance Details";
}

<h1>Attendance Details</h1>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Student</dt>
            <dd class="col-sm-9">@Model.CourseEnrolment?.StudentProfile?.Name</dd>
            
            <dt class="col-sm-3">Course</dt>
            <dd class="col-sm-9">@Model.CourseEnrolment?.Course?.Name</dd>
            
            <dt class="col-sm-3">Week Number</dt>
            <dd class="col-sm-9">@Model.WeekNumber</dd>
            
            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9">@Model.Date.ToShortDateString()</dd>
            
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.Present)
                {
                    <span class="badge bg-success">Present</span>
                }
                else
                {
                    <span class="badge bg-danger">Absent</span>
                }
            </dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>