@model VgcCollege.Web.Models.Course

@{
    ViewData["Title"] = "Course Details";
}

<h1>Course Details</h1>

<div class="card mb-3">
    <div class="card-header">
        <h3>@Model.Name</h3>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Branch</dt>
            <dd class="col-sm-9">@Model.Branch?.Name</dd>
            
            <dt class="col-sm-3">Faculty</dt>
            <dd class="col-sm-9">@Model.FacultyProfile?.Name</dd>
            
            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>
            
            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>
            
            <dt class="col-sm-3">Total Students</dt>
            <dd class="col-sm-9">@Model.Enrolments.Count</dd>
        </dl>
    </div>
</div>

<h3>Enrolled Students</h3>
<table class="table table-striped">
    <thead>
    <tr>
    <th>Student Name</th>
    <th>Student Number</th>
    <th>Email</th>
    <th>Enrolment Date</th>
    <th>Status</th>
    </thead>
    <tbody>
    @foreach (var enrolment in Model.Enrolments)
    {
        <tr>
        <td>@enrolment.StudentProfile?.Name</td
        td@enrolment.StudentProfile?.StudentNumber</td
        td@enrolment.StudentProfile?.Email</td
            td@enrolment.EnrolDate.ToShortDateString()</td
            td@enrolment.Status</td
            </tr
    }
    </tbody>
</table>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>