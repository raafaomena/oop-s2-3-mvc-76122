@model VgcCollege.Web.Models.Course

@{
    ViewData["Title"] = "Delete Course";
}

<h1>Delete Course</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this course?</h3>
    <p>This will also delete all enrolments, assignments, and exams associated with this course.</p>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>
            
            <dt class="col-sm-3">Branch</dt>
            <dd class="col-sm-9">@Model.Branch?.Name</dd>
            
            <dt class="col-sm-3">Enrolled Students</dt>
            <dd class="col-sm-9">@Model.Enrolments.Count</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>